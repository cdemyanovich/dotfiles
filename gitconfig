[user]
	name = Craig Demyanovich
	email = cdemyanovich@gmail.com
[includeIf "gitdir/i:~/work/"]
  path = ~/work/.gitconfig
[includeIf "gitdir/i:~/work/groupon/"]
  path = ~/work/groupon/.gitconfig
[includeIf "gitdir/i:~/work/ticketmaster/"]
  path = ~/work/ticketmaster/.gitconfig
[alias]
	st = status
	co = checkout
	ci = commit
	del = !"git status | grep deleted | cut -d' ' -f 5 | xargs git rm 2> /dev/null"
	up = !"say git up git up git up and jump around"
	br = branch
	find = grep --break --heading --line-number --ignore-case
[push]
	default = current
	autoSetupRemote = true
	followTags = true
[github]
	user = cdemyanovich
[help]
        autocorrect = prompt
[core]
        excludesfile = ~/.gitignore
[branch]
	autosetuprebase = always
	sort = -committerdate
[rerere]
	enabled = 0
[filter "lfs"]
	clean = git-lfs clean -- %f
	smudge = git-lfs smudge -- %f
	process = git-lfs filter-process
	required = true
[fetch]
	prune = true
	pruneTags = true
	all = true
[diff]
	algorithm = histogram
	colorMoved = plain
	mnemonicPrefix = true
	renames = true
[commit]
	verbose = true
