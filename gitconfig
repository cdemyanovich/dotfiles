[alias]
	st = status
	co = checkout
	ci = commit
	del = !"git status | grep deleted | cut -d' ' -f 5 | xargs git rm 2> /dev/null"
	up = !"say git up git up git up and jump around"
	br = branch
	find = grep --break --heading --line-number --ignore-case
[branch]
	autosetuprebase = always
	sort = -committerdate
[commit]
	verbose = true
[core]
        excludesfile = ~/.gitignore
[diff]
	algorithm = histogram
	colorMoved = plain
	mnemonicPrefix = true
	renames = true
[github]
	user = cdemyanovich
[fetch]
	all = true
	prune = true
	pruneTags = true
[filter "lfs"]
	clean = git-lfs clean -- %f
	smudge = git-lfs smudge -- %f
	process = git-lfs filter-process
	required = true
[help]
        autocorrect = prompt
[merge]
	conflictstyle = zdiff3
[pull]
	rebase = true
[push]
	autoSetupRemote = true
	default = current
	followTags = true
[rerere]
	enabled = false
[user]
	email = cdemyanovich@gmail.com
	name = Craig Demyanovich
[includeIf "gitdir/i:~/work/"]
  path = ~/work/.gitconfig
[includeIf "gitdir/i:~/work/groupon/"]
  path = ~/work/groupon/.gitconfig
[includeIf "gitdir/i:~/work/ticketmaster/"]
  path = ~/work/ticketmaster/.gitconfig
